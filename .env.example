# ─────────────────────────────────────────────
#  Fixly Backend — Environment Configuration
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# PostgreSQL — Prisma connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/fixly_db?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,https://yourfrontend.vercel.app

# Admin default password (used in seed only)
ADMIN_DEFAULT_PASSWORD=Admin@Fixly2024

# Optional: Cloudinary (for profile image uploads)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
